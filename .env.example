# Local integration server
PORT=8787
APP_URL=http://127.0.0.1:4173
# Comma-separated frontend origins allowed to call a separately deployed API.
CORS_ORIGINS=

# Google Places API (New)
# Enable Places API (New), attach billing, and restrict this server key by IP and API.
GOOGLE_PLACES_API_KEY=

# Yelp Places / Fusion API
YELP_API_KEY=

# OpenStreetMap Nominatim requires an identifying application contact.
OSM_CONTACT_EMAIL=
OSM_NOMINATIM_URL=https://nominatim.openstreetmap.org

# Optional permitted public-directory adapter.
# The URL is controlled by the app owner, not by browser input.
# Supported placeholders: {query}, {location}, {limit}
DIRECTORY_NAME=Public directory
DIRECTORY_API_URL_TEMPLATE=
DIRECTORY_API_KEY=
DIRECTORY_API_KEY_HEADER=Authorization
DIRECTORY_API_KEY_PREFIX=Bearer
DIRECTORY_RESULTS_PATH=results

# LinkedIn OpenID Connect. This connects the signed-in member's own identity.
# It does not enable LinkedIn lead search. Prospect APIs require LinkedIn approval.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://127.0.0.1:8787/api/linkedin/callback
